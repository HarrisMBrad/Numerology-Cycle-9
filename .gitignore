# Ignore system & environment files
.DS_Store
Thumbs.db
.env
*.log

# VS Code project settings
.vscode/settings.json

# Ignore config and credentials
/config/
*.yaml
*.yml
*.json
*.ini
*.cfg
*.toml
secrets.*

# Ignore Python bytecode and caches (if scripting)
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Ignore compiled scripts and binaries
*.exe
*.out
*.class
*.bin

# Ignore archives & exports
*.zip
*.tar.gz
*.rar
*.7z

# Ignore local development files
.idea/
.vscode/
*.swp
*.bak

# Optional: ignore markdown logs or test cycles
logs/
journal/
drafts/
