    "# Robust Titanic loader + baseline -> writes /kaggle/working/submission.csv\n",
    "\n",
    "import os\n",
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "def find_csvs():\n",
    "    candidates = [\n",
    "        (Path(\"/kaggle/input/titanic/train.csv\"), Path(\"/kaggle/input/titanic/test.csv\")),\n",
    "        (Path(\"./train.csv\"), Path(\"./test.csv\")),\n",
    "        (Path(\"/kaggle/working/train.csv\"), Path(\"/kaggle/working/test.csv\")),\n",
    "    ]\n",
    "    for tr, te in candidates:\n",
    "        if tr.exists() and te.exists():\n",
    "            return tr, te\n",
    "    return None, None\n",
    "\n",
    "# Try to locate data\n",
    "train_path, test_path = find_csvs()\n",
    "\n",
    "# Debug info\n",
    "print(\"PWD:\", os.getcwd())\n",
    "print(\"Have Kaggle input dir?:\", Path(\"/kaggle/input\").exists())\n",
    "if Path(\"/kaggle/input\").exists():\n",
    "    print(\"Contents of /kaggle/input:\", list(Path(\"/kaggle/input\").glob(\"*\")))\n",
    "print(\"Local files:\", [p.name for p in Path(\".\").glob(\"*.csv\")])\n",
    "\n",
    "if train_path is None:\n",
    "    raise FileNotFoundError(\n",
    "        \"Could not find train.csv and test.csv.\\n\"\n",
    "        \"Fix: In the right sidebar, click 'Add data' → search 'Titanic — Machine Learning from Disaster' → Add.\\n\"\n",
    "        \"OR upload train.csv and test.csv to this notebook's working directory, then rerun.\"\n",
    "    )\n",
    "\n",
    "print(\"Using:\", train_path, \"|\", test_path)\n",
    "\n",
    "# Load\n",
    "train = pd.read_csv(train_path)\n",
    "test  = pd.read_csv(test_path)\n",
    "print(\"Train/Test shapes:\", train.shape, test.shape)\n",
    "\n",
    "# Features and target\n",
    "target = \"Survived\"\n",
    "id_col = \"PassengerId\"\n",
    "num_features = [\"Age\", \"Fare\", \"SibSp\", \"Parch\"]\n",
    "cat_features = [\"Pclass\", \"Sex\", \"Embarked\"]\n",
    "\n",
    "X = train[num_features + cat_features].copy()\n",
    "y = train[target].astype(int)\n",
    "X_test = test[num_features + cat_features].copy()\n",
    "\n",
    "# Pipeline\n",
    "numeric = Pipeline([(\"imputer\", SimpleImputer(strategy=\"median\"))])\n",
    "categorical = Pipeline([\n",
    "    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "    (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)),\n",
    "])\n",
    "preprocess = ColumnTransformer([\n",
    "    (\"num\", numeric, num_features),\n",
    "    (\"cat\", categorical, cat_features),\n",
    "])\n",
    "pipe = Pipeline([(\"prep\", preprocess), (\"model\", LogisticRegression(max_iter=200))])\n",
    "\n",
    "# CV\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "scores = cross_val_score(pipe, X, y, cv=cv, scoring=\"accuracy\", n_jobs=-1)\n",
    "print(f\"CV accuracy: {scores.mean():.4f} ± {scores.std():.4f}\")\n",
    "\n",
    "# Fit and predict\n",
    "pipe.fit(X, y)\n",
    "pred = pipe.predict(X_test).astype(int)\n",
    "\n",
    "# Submission\n",
    "sub = pd.DataFrame({id_col: test[id_col], \"Survived\": pred})\n",
    "out = Path(\"/kaggle/working/submission.csv\")\n",
    "sub.to_csv(out, index=False)\n",
    "print(\"Wrote:\", out)\n",
    "sub.head()\n"
   ]
  },
