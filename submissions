    "# Quick feature engineering + re-train\n",
    "import re\n",
    "def title_from_name(s):\n",
    "    m = re.search(r\",\\s*([^\\.]+)\\.\", s)\n",
    "    t = (m.group(1).strip() if m else \"Unknown\")\n",
    "    return {\"Mlle\":\"Miss\",\"Ms\":\"Miss\",\"Mme\":\"Mrs\",\"Lady\":\"Royalty\",\"Countess\":\"Royalty\",\n",
    "            \"Sir\":\"Royalty\",\"Don\":\"Royalty\",\"Jonkheer\":\"Royalty\",\"Capt\":\"Officer\",\n",
    "            \"Col\":\"Officer\",\"Major\":\"Officer\",\"Dr\":\"Officer\",\"Rev\":\"Officer\"}.get(t,t)\n",
    "\n",
    "for df in (train, test):\n",
    "    df[\"FamilySize\"] = df[\"SibSp\"].fillna(0) + df[\"Parch\"].fillna(0) + 1\n",
    "    df[\"IsAlone\"] = (df[\"FamilySize\"]==1).astype(int)\n",
    "    df[\"Title\"] = df[\"Name\"].apply(title_from_name)\n",
    "\n",
    "num_features = [\"Age\",\"Fare\",\"SibSp\",\"Parch\",\"FamilySize\",\"IsAlone\"]\n",
    "cat_features = [\"Pclass\",\"Sex\",\"Embarked\",\"Title\"]\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "numeric = Pipeline([(\"imputer\", SimpleImputer(strategy=\"median\"))])\n",
    "categorical = Pipeline([(\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "                        (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False))])\n",
    "preprocess = ColumnTransformer([(\"num\", numeric, num_features),\n",
    "                                (\"cat\", categorical, cat_features)])\n",
    "pipe = Pipeline([(\"prep\", preprocess),\n",
    "                 (\"model\", RandomForestClassifier(n_estimators=400, max_depth=5, random_state=42))])\n",
    "\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "X = train[num_features + cat_features]; y = train[\"Survived\"].astype(int)\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "print(\"CV acc:\", cross_val_score(pipe, X, y, cv=cv, scoring=\"accuracy\", n_jobs=-1).mean().round(4))\n",
    "\n",
    "pipe.fit(X, y)\n",
    "pred = pipe.predict(test[num_features + cat_features]).astype(int)\n",
    "pd.DataFrame({\"PassengerId\": test[\"PassengerId\"], \"Survived\": pred}).to_csv(\"/kaggle/working/submission.csv\", index=False)\n",
    "print(\"Wrote /kaggle/working/submission.csv\")\n"
   ]
